      "name": "When clicking ‘Execute workflow’"
    },
    {
      "parameters": {
        "jsCode": "for (const item of items) {\n  const text = item.json.post_text;\n  \n  // 1. Clean text: remove URLs, anonymize @mentions\n  let cleanText = text.replace(/http\\S+/g, '');\n  cleanText = cleanText.replace(/@\\S+/g, '@user');\n  \n  // 2. Extract hashtags (array of strings without #)\n  const hashtagMatches = text.match(/#(\\w+)/g) || [];\n  const hashtags = hashtagMatches.map(tag => tag.substring(1)); // remove '#'\n  \n  // 3. Flag ads\n  const lowerText = text.toLowerCase();\n  const isAd = lowerText.includes('#ad') || \n                lowerText.includes('#sponsored') || \n                lowerText.includes('giveaway');\n  \n  // 4. Add new fields to the item\n  item.json.clean_text = cleanText;\n  item.json.hashtags = hashtags;\n  item.json.is_ad = isAd;\n}\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -304,
        0
      ],
      "id": "79636e70-3b2e-4532-b405-16c83bcb514a",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// Simple sentiment lexicon for coffee social media\nconst positiveWords = ['good', 'great', 'awesome', 'love', 'best', 'perfect', 'amazing', 'happy', 'excellent', 'favorite', 'delicious', 'enjoy', 'beautiful', 'notes', 'vibe', 'craft', 'perfect', 'pour', 'slow', 'farm', 'experience', 'training', 'remember', 'favorite', 'rare', 'insane'];\nconst negativeWords = ['bad', 'terrible', 'hate', 'worst', 'disappointed', 'slow', 'wait', 'frustrating', 'burnt', 'issue', 'sorry', 'problem', 'long line', 'sticker', 'frustrated'];\n\nfor (const item of items) {\n  const text = item.json.clean_text.toLowerCase();\n  const words = text.split(/\\W+/);\n  \n  let score = 0;\n  for (const word of words) {\n    if (positiveWords.includes(word)) score += 1;\n    if (negativeWords.includes(word)) score -= 1;\n  }\n  \n  // Determine sentiment label\n  let label = 'neutral';\n  let probability = 0.5;\n  if (score > 0) {\n    label = 'pos';\n    probability = 0.6 + (score * 0.1);\n  } else if (score < 0) {\n    label = 'neg';\n    probability = 0.6 + (Math.abs(score) * 0.1);\n  }\n  \n  // Add sentiment fields matching the API format\n  item.json.sentiment_label = label;\n  item.json.sentiment_score = score;\n  item.json.sentiment_probability = Math.min(probability, 0.99);\n}\n\nreturn items;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        0
      ],
      "id": "39edd88f-a101-4be9-964f-81f97e3eb617",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "for (const item of items) {\n  // Get existing data\n  const hashtags = item.json.hashtags || [];\n  const cleanText = item.json.clean_text || '';\n  const lowerText = cleanText.toLowerCase();\n  \n  // Categorization logic\n  let category = 'General';\n  \n  // Check for Promotion\n  const hashtagString = hashtags.join(' ').toLowerCase();\n  if (hashtagString.includes('ad') || hashtagString.includes('sweepstakes') || hashtagString.includes('sponsored')) {\n    category = 'Promotion';\n  }\n  // Check for Service Issue\n  else if (lowerText.match(/wait|long line|slow|frustrat|sorry|issue/)) {\n    category = 'Service Issue';\n  }\n  \n  // Add category field\n  item.json.category = category;\n}\n\nreturn items;\n"
      },
